<main>
    <section class="hero">
        <div class="hero-left-wrapper">
            <div class="hero-main-heading">
                <h1>BUSINESS</h1>
            </div>
            <section class="hero-left scrollable">
                <div class="su">
                    <button style="background-image: url(assets/background.png);">
                        <img src="assets/down-arrow.svg" alt="">
                    </button>
                </div>
                <% for (let i=0; i<=7;i++) { %>
                    <article>
                        <img src="<%=leftData[i].Photo%>" alt="Article Image"
                            onerror="this.src='assets/news-placeholder.png'">
                        <div class="article-details">
                            <h2>
                                <%= leftData[i].Headline %>
                            </h2>
                            <div class="byline">
                                <span>
                                    <%= leftData[i].Date %>
                                </span>
                                <span>-Times Of India</span>
                            </div>
                        </div>
                    </article>
                    <%}%>
                        <div class="sd">
                            <button style="background-image: url(assets/background.png);">
                                <img src="assets/down-arrow.svg" alt="">
                            </button>
                        </div>
            </section>
        </div>
        <!-- HERO MIDDLE -->
        <div class="hero-main-wrapper">
            <div class="hero-main-heading">
                <h1>LATEST NEWS</h1>
            </div>
            <section class="hero-main">
                <div class="hero-main-left scrollable">
                    <div class="su">
                        <button style="background-image: url(assets/background.png);">
                            <img src="assets/down-arrow.svg" alt="">
                        </button>
                    </div>
                    <div class="hero-main-left-img">
                        <img src="<%= data[0].Photo %>" alt="">
                    </div>
                    <div class="hero-main-left-details">
                        <h2 id="hlfontchange">
                            <%= data[0].Headline %>
                        </h2>
                        <p id="main-story">
                            <%- data[0].Story %>
                        </p>


                        <div class="byline">
                            <span>
                                <%= data[0].Date %>
                            </span>
                            <span>
                                -<%= data[0].ByLine %>
                            </span>
                        </div>
                    </div>
                    <div class="sd">
                        <button style="background-image: url(assets/background.png);">
                            <img src="assets/down-arrow.svg" alt="">
                        </button>
                    </div>

                </div>
                <div class="hero-main-right">
                    <% for (let i=1; i<=4;i++) { %>
                        <article>
                            <img src="<%= data[i].Photo %>" alt="article-img"
                                onerror="this.src='assets/news-placeholder.png'">
                            <div class="article-details">
                                <h2>
                                    <%= data[i].Headline %>
                                </h2>
                                <div class="byline">
                                    <span>
                                        <%= data[i].Date %>
                                    </span>
                                    <span>
                                        -<%= data[i].ByLine %>
                                    </span>
                                </div>
                            </div>
                        </article>
                        <%}%>
                </div>

            </section>
        </div>

        <div class="hero-right-wrapper">
            <div class="hero-right-heading">
                <h1>Quotes</h1>
            </div>
            <div class="quote-wrapper scrollable">
                <div class="su">
                    <button style="background-image: url(assets/background.png);">
                        <img src="assets/down-arrow.svg" alt="">
                    </button>
                </div>
                <% for (let i=0;i<quoteImg.length;i++) {%>
                    <div class="hero-right-quotes">
                        <img src="<%= quoteImg[i].src.medium %>" alt="Image displaying the qutoes">
                        <h2>
                            <%= quoteArr[i].q %>
                        </h2>
                    </div>
                    <%}%>
                        <div class="sd">
                            <button style="background-image: url(assets/background.png);">
                                <img src="assets/down-arrow.svg" alt="">
                            </button>
                        </div>
            </div>
            <div class="coffee">
                <img src="assets/filler-vines.svg" alt="">
            </div>
        </div>
    </section>

</main>