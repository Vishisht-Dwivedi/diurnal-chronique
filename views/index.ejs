<%- include('header.ejs') %>

    <div class="headline">
        <h1>Latest Headlines</h1>
    </div>
    <%- include('hero.ejs') %>
        <section class="more-items-section">
            <div class="headline">
                <h1>More Headlines</h1>
            </div>
            <div class="more-items">

                <% for (let i=4; i<data.length;i++) { %>
                    <article class="aside-articles">
                        <div class="article-img">
                            <img src="<%= data[i].Photo %>" alt="No image could be displayed"
                                onerror="this.src='assets/news-placeholder.png'" loading="lazy">
                        </div>
                        <div class="article-details">
                            <div>
                                <h2>
                                    <%if (data[i].Headline.length> 80) { %>
                                        <%= data[i].Headline.slice(0,80) + '...' %>
                                            <% } else {%>
                                                <%= data[i].Headline %>
                                                    <%}%>

                                </h2>
                            </div>

                            <div class="tagLines">
                                <span class="dateline">
                                    <%= data[i].Date %>
                                </span>
                                <span class="byline">-
                                    <%if (data[i].ByLine) {%>
                                        <%= data[i].ByLine %>
                                            <%} else {%>
                                                Times Of India
                                                <%}%>
                                </span>
                            </div>
                        </div>

                    </article>
                    <% }%>
            </div>
        </section>
        <div class="read-more">
            <div class="read-more-btn">
                Read More
            </div>
        </div>

        <%- include('footer.ejs') %>